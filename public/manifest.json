{
  "manifest_version": 3,
  "name": "Grensa.AI - Telegram Chat Analyzer",
  "version": "1.0.0",
  "description": "Анализирует чаты Telegram и генерирует краткие резюме с помощью AI",
  "icons": {
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "activeTab", 
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://web.telegram.org/*",
    "https://api.openai.com/*"
  ],
  "action": {
    "default_title": "Grensa.AI - Анализ чата",
    "default_popup": "index.html",
    "default_icon": "icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["https://web.telegram.org/*"],
      "js": ["static/js/content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "static/js/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["static/js/*.js", "static/css/*.css"],
      "matches": ["https://web.telegram.org/*"]
    }
  ]
}
